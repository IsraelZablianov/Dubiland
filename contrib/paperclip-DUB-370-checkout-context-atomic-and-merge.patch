+  // Coalescing must not retarget an already issue-bound run to a different issue.
+  // Otherwise a running run's context_snapshot can drift (locks on issue A while
+  // snapshot references issue B) — see lock-integrity remediation (DUB-314).
+  const existingBound =
+    readNonEmptyString(existing.issueId) ?? readNonEmptyString(existing.taskId);
+  const incomingBound =
+    readNonEmptyString(incoming.issueId) ?? readNonEmptyString(incoming.taskId);
+  if (existingBound && incomingBound && existingBound !== incomingBound) {
+    merged.issueId = existing.issueId;
+    merged.taskId = existing.taskId;
+    merged.taskKey = existing.taskKey;
+  } else if (existingBound && !incomingBound) {
+    // DUB-370: `{ ...existing, ...incoming }` lets incoming use `issueId: null` or omit
+    // identity keys, wiping a bound snapshot after checkout. Preserve the binding.
+    merged.issueId = existing.issueId;
+    merged.taskId = existing.taskId;
+    merged.taskKey = readNonEmptyString(merged.taskKey as unknown)
+      ? merged.taskKey
+      : existing.taskKey;
+  }
