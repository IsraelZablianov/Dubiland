index 0000000..ede6349
--- /dev/null
+++ b/server/src/services/issue-manager-assignee-guardrail.ts
@@ -0,0 +1,122 @@
+import { and, asc, eq, inArray, notInArray } from "drizzle-orm";
+import type { Db } from "@paperclipai/db";
+import { agents } from "@paperclipai/db";
+import type { AgentRole } from "@paperclipai/shared";
+import { unprocessable } from "../errors.js";
+
+const MANAGER_ASSIGNMENT_ROLES = new Set<AgentRole>(["ceo", "cto", "cmo", "cfo", "pm"]);
+
+const IC_ASSIGNMENT_ROLES: AgentRole[] = [
+  "engineer",
+  "designer",
+  "qa",
+  "devops",
+  "researcher",
+  "general",
+];
+
+const IMPLEMENTATION_LANE_BRACKET_RE =
+  /\[(?:FED|Backend|QA|Performance|Architect|UX|Media|SEO|Content|Gaming|DevOps)\b[^\]]*\]/i;
+
+const IMPLEMENTATION_TITLE_PREFIX_RE = /^Implement(?:ing)?\b/i;
+
+export function isImplementationLaneTitle(title: string): boolean {
+  const t = title.trim();
+  if (IMPLEMENTATION_TITLE_PREFIX_RE.test(t)) return true;
+  return IMPLEMENTATION_LANE_BRACKET_RE.test(t);
+}
+
+export function isManagerAssignmentRole(role: string): boolean {
+  return MANAGER_ASSIGNMENT_ROLES.has(role as AgentRole);
+}
+
+export type ManagerAssigneeGuardrailResolution =
+  | { kind: "noop" }
+  | { kind: "override_allowed"; managerAgentId: string }
+  | { kind: "rerouted"; fromAgentId: string; toAgentId: string | null };
+
+export type ManagerAssigneeGuardrailLogDetails = {
+  outcome: "rerouted" | "override";
+  implementationLaneTitle: true;
+  fromAgentId: string;
+  toAgentId: string | null;
+  rationalePreview?: string;
+};
+
+async function pickDefaultIcAgent(db: Pick<Db, "select">, companyId: string): Promise<string | null> {
+  const row = await db
+    .select({ id: agents.id })
+    .from(agents)
+    .where(
+      and(
+        eq(agents.companyId, companyId),
+        inArray(agents.role, IC_ASSIGNMENT_ROLES),
+        notInArray(agents.status, ["pending_approval", "terminated"]),
+      ),
+    )
+    .orderBy(asc(agents.name))
+    .limit(1)
+    .then((rows) => rows[0] ?? null);
+  return row?.id ?? null;
+}
+
+export async function resolveManagerAssigneeGuardrail(
+  db: Pick<Db, "select">,
+  companyId: string,
+  input: {
+    title: string;
+    assigneeAgentId: string;
+    managerAssigneeOverride?: boolean | null;
+    managerAssigneeOverrideRationale?: string | null;
+  },
+): Promise<{
+  assigneeAgentId: string | null;
+  resolution: ManagerAssigneeGuardrailResolution;
+  logDetails: ManagerAssigneeGuardrailLogDetails | null;
+}> {
+  if (!isImplementationLaneTitle(input.title)) {
+    return { assigneeAgentId: input.assigneeAgentId, resolution: { kind: "noop" }, logDetails: null };
+  }
+
+  const assigneeRow = await db
+    .select({ id: agents.id, role: agents.role })
+    .from(agents)
+    .where(and(eq(agents.id, input.assigneeAgentId), eq(agents.companyId, companyId)))
+    .then((rows) => rows[0] ?? null);
+
+  if (!assigneeRow || !isManagerAssignmentRole(assigneeRow.role)) {
+    return { assigneeAgentId: input.assigneeAgentId, resolution: { kind: "noop" }, logDetails: null };
+  }
+
+  if (input.managerAssigneeOverride === true) {
+    const rationale = input.managerAssigneeOverrideRationale?.trim() ?? "";
+    if (rationale.length < 10) {
+      throw unprocessable(
+        "managerAssigneeOverride requires managerAssigneeOverrideRationale with at least 10 characters",
+      );
+    }
+    return {
+      assigneeAgentId: input.assigneeAgentId,
+      resolution: { kind: "override_allowed", managerAgentId: input.assigneeAgentId },
+      logDetails: {
+        outcome: "override",
+        implementationLaneTitle: true,
+        fromAgentId: input.assigneeAgentId,
+        toAgentId: input.assigneeAgentId,
+        rationalePreview: rationale.slice(0, 240),
+      },
+    };
+  }
+
+  const toAgentId = await pickDefaultIcAgent(db, companyId);
+  return {
+    assigneeAgentId: toAgentId,
+    resolution: { kind: "rerouted", fromAgentId: input.assigneeAgentId, toAgentId },
+    logDetails: {
+      outcome: "rerouted",
+      implementationLaneTitle: true,
+      fromAgentId: input.assigneeAgentId,
+      toAgentId,
+    },
+  };
+}
