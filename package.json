{
  "name": "dubiland",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "yarn workspace @dubiland/web dev",
    "build": "yarn workspace @dubiland/web build",
    "assets:optimize": "yarn workspace @dubiland/web images:optimize",
    "assets:budgets": "yarn workspace @dubiland/web images:budgets",
    "assets:pipeline": "yarn workspace @dubiland/web images:pipeline",
    "typecheck": "yarn workspaces foreach -A run typecheck",
    "audio:validate-manifest": "node scripts/validate-audio-manifest.mjs",
    "generate-audio": "python3 scripts/generate-audio.py",
    "generate-audio:audit-punctuation": "python3 scripts/generate-audio.py --audit-punctuation",
    "generate-audio:force": "python3 scripts/generate-audio.py --force",
    "paperclip": "npx paperclipai run",
    "cascade": "npx paperclipai heartbeat run --agent-id 9ba06101-670c-4da3-9d57-56fdc8d67b03",
    "adapter": "bash scripts/switch-adapter.sh",
    "supabase:types": "npx supabase gen types typescript --local --schema public > packages/shared/src/types/database.ts",
    "supabase:types:linked": "npx supabase gen types typescript --linked --schema public > packages/shared/src/types/database.ts",
    "test:automation-recovery-gateway": "npx --yes deno test supabase/functions/automation-recovery-gateway/handler_test.ts --allow-env",
    "test:guardrail-v2": "node --test scripts/manager-assignee-guardrail-v2.test.mjs",
    "perf:provision-auth-user": "node scripts/provision-dubiland-perf-auth-user.mjs",
    "perf:check-auth-env": "node scripts/check-dubiland-perf-auth-env.mjs --load-dotenv"
  },
  "devDependencies": {
    "@google/genai": "^1.49.0",
    "puppeteer": "^24.40.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  },
  "packageManager": "yarn@4.12.0+sha512.f45ab632439a67f8bc759bf32ead036a1f413287b9042726b7cc4818b7b49e14e9423ba49b18f9e06ea4941c1ad062385b1d8760a8d5091a1a31e5f6219afca8"
}
