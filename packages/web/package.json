{
  "name": "@dubiland/web",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node ../../scripts/check-web-vite-supabase-env.mjs && vite",
    "build": "node ./scripts/build-production.mjs",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "check:prod-runtime": "node ./scripts/assert-production-react-runtime.mjs",
    "test:audio-playback-queue": "TSX_TSCONFIG_PATH=./tsconfig.json node --import tsx --test ./scripts/audio-playback-queue.test.mjs",
    "test:interactive-handbook-runtime": "TSX_TSCONFIG_PATH=./tsconfig.json node --import tsx --test ./scripts/interactive-handbook-runtime-regression.test.mjs",
    "test:handbook-runtime": "yarn test:interactive-handbook-runtime",
    "test:nikud-sound-ladder-prototype": "node --import tsx --test ./scripts/nikud-sound-ladder-prototype.test.mjs",
    "test:aria-prohibited-hud": "node --test ./scripts/aria-prohibited-hud-regression.test.mjs",
    "test:touch-shell": "node --test ./scripts/touch-shell-regression.test.mjs",
    "test:protected-route-guard": "node --test ./scripts/protected-route-guard-smoke.test.mjs",
    "images:optimize": "node ./scripts/optimize-images.mjs",
    "images:contact-sheet": "node ./scripts/rebuild-thumbnail-contact-sheet.mjs",
    "images:budgets": "node ./scripts/check-image-budgets.mjs",
    "images:pipeline": "yarn images:optimize && yarn images:contact-sheet && yarn images:budgets",
    "generate:crawl-assets": "node ./scripts/generate-crawl-assets.mjs",
    "generate:crawl-assets:dist": "node ./scripts/generate-crawl-assets.mjs --dist",
    "perf:ci:bundle": "node ./scripts/check-ci-bundle-budgets.mjs",
    "perf:ci:lighthouse": "node ./scripts/run-ci-lighthouse-gate.mjs",
    "perf:ci:summary": "node ./scripts/generate-ci-perf-summary.mjs"
  },
  "dependencies": {
    "@dubiland/shared": "workspace:*",
    "@supabase/supabase-js": "^2.49.0",
    "i18next": "^24.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-i18next": "^15.0.0",
    "react-router-dom": "^7.0.0"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.4.0",
    "sharp": "^0.34.5",
    "typescript": "^5.7.0",
    "vite": "^6.0.0",
    "vite-plugin-pwa": "^1.0.3"
  }
}
