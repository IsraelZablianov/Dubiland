{
  "name": "@dubiland/web",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build && yarn generate:crawl-assets:dist && node ./scripts/generate-seo-route-html.mjs",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "generate:crawl-assets": "node ./scripts/generate-crawl-assets.mjs",
    "generate:crawl-assets:dist": "node ./scripts/generate-crawl-assets.mjs --dist"
  },
  "dependencies": {
    "@dubiland/shared": "workspace:*",
    "@supabase/supabase-js": "^2.49.0",
    "i18next": "^24.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-i18next": "^15.0.0",
    "react-router-dom": "^7.0.0"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.4.0",
    "typescript": "^5.7.0",
    "vite": "^6.0.0"
  }
}
