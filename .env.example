# Dubiland Environment Variables

# Nano Banana (Gemini) API Key — used for AI image generation
# Get from https://aistudio.google.com/apikey (requires active billing on the GCP project)
# Models: gemini-2.5-flash-image, gemini-3.1-flash-image-preview, gemini-3-pro-image-preview
# Fallback: use Gemini web UI at gemini.google.com with enterprise account (Fast mode)
NANO_BANANA_API_KEY=your_api_key_here

# Supabase (web — anon key only; never put service_role in Vite env)
# Repo root `.env` is required for `yarn dev` (validated by scripts/check-web-vite-supabase-env.mjs).
# Offline-only dev: SKIP_WEB_VITE_ENV_CHECK=1 yarn dev
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# Parent funnel conversion UX rollout (landing/parents/login tune-up)
# false = current baseline experience, true = trust-rail + conversion CTA + login reassurance flow
VITE_PARENT_FUNNEL_CONVERSION_TUNEUP_ENABLED=false

# Supabase CLI / Management API (Account Settings → Access Tokens). Repo key name is SUPBASE_TOKEN (historic spelling).
SUPBASE_TOKEN=

# Optional: same value as the subdomain in VITE_SUPABASE_URL (set automatically after `npx supabase link`)
SUPABASE_PROJECT_REF=

# Script-only service role for local automation (e.g. perf auth provisioning). NEVER add to Vite / client env.
SUPABASE_SERVICE_ROLE_KEY=

# Protected-route Lighthouse matrix — authenticated profile (scripts/dub-637-protected-route-matrix.mjs).
# Provision once: `yarn perf:provision-auth-user` (requires SUPABASE_SERVICE_ROLE_KEY + VITE_SUPABASE_URL in .env).
# Inject into Paperclip/workspace .env for Performance Expert heartbeats; never commit real values.
DUBILAND_PERF_EMAIL=
DUBILAND_PERF_PASSWORD=

# Authenticated handbook QA (DUB-578 / DUB-749) — separate test parent from perf matrix.
# Provision: `yarn handbook:qa:provision-auth-user` (requires SUPABASE_SERVICE_ROLE_KEY + VITE_SUPABASE_URL).
# Verify presence only: `yarn handbook:qa:check-auth-env`
DUBILAND_HANDBOOK_QA_EMAIL=
DUBILAND_HANDBOOK_QA_PASSWORD=

# Google sign-in: enable the Google provider in Supabase Dashboard → Authentication → Providers,
# add OAuth Client ID + Secret from Google Cloud, and keep Site URL / Redirect URLs in sync with `yarn dev` (e.g. http://127.0.0.1:5173).
